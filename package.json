  "main": "api/server.ts",
  "type": "module",
  "scripts": {
    "start": "tsx api/server.ts",
    "dev": "tsx --watch api/server.ts",
    "build": "tsc",
    "dev:css": "tailwindcss -i ./public/css/input.css -o ./public/css/style.css --watch",
